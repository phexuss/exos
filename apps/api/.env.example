NODE_ENV=development
PORT=3000
SWAGGER_ENABLED=false

DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require
REDIS_URL=redis://localhost:6379

YTDLP_PATH=/usr/bin/yt-dlp
YTDLP_TIMEOUT_MS=10000
YTDLP_MAX_CONCURRENT=3
# Optional diagnostic probe. Set to 1 to log whether resolved CDN URLs work server-side.
YTDLP_STREAM_URL_PROBE=0
# Optional advanced yt-dlp YouTube extractor args, e.g. youtube:player_client=default,-web
YTDLP_YOUTUBE_EXTRACTOR_ARGS=
# How long to fail fast after YouTube returns "not a bot" instead of hammering yt-dlp.
YTDLP_YOUTUBE_BOT_CHECK_COOLDOWN_SEC=300
# Optional comma-separated hosts to redirect directly instead of proxying.
# Keep empty when SoundCloud/YouTube URLs are IP-bound and must go through server proxy.
STREAM_DIRECT_HOSTS=
# Netscape cookies file for YouTube auth (optional)
YTDLP_COOKIES_PATH=

JWT_ACCESS_SECRET=replace-with-at-least-32-random-characters
JWT_REFRESH_SECRET=replace-with-another-32-random-characters
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=30d

LASTFM_API_KEY=
RESEND_API_KEY=re_replace_with_real_key
RESEND_TEST_ENDPOINT_ENABLED=false
