generator client {
  provider = "prisma-client-js"
  output   = "./generated"
}

datasource db {
  provider = "postgresql"
}

model User {
  id             String             @id @default(uuid())
  name           String
  email          String             @unique
  username       String             @unique
  passwordHash   String
  isVerified     Boolean            @default(false)
  verifyToken    String?            @unique
  verifyTokenExp DateTime?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  userLibraries  UserLibrary[]
  recentlyPlayed UserRecentlyPlayed[]
  sessions       Session[]
  codes          VerificationCode[]
}

model VerificationCode {
  id        String   @id @default(uuid())
  code      String
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model UserLibrary {
  id          String   @id @default(uuid())
  userId      String
  trackId     String?
  deezerId    String?
  scUrl       String?
  source      String
  title       String
  artistName  String
  artistId    String?
  album       String?
  coverUrl    String?
  duration    String
  durationSec Int      @default(0)
  previewUrl  String?
  isrc        String?
  addedAt     DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, deezerId])
  @@unique([userId, scUrl])
  @@index([userId, addedAt])
}

model UserRecentlyPlayed {
  id          String   @id @default(uuid())
  userId      String
  trackId     String?
  deezerId    String?
  scUrl       String?
  source      String
  title       String
  artistName  String
  artistId    String?
  album       String?
  coverUrl    String?
  duration    String
  durationSec Int      @default(0)
  previewUrl  String?
  isrc        String?
  playedAt    DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, deezerId])
  @@unique([userId, scUrl])
  @@index([userId, playedAt])
}

model Session {
  id               String   @id @default(uuid())
  userId           String
  refreshTokenHash String   @unique
  device           String?
  expiresAt        DateTime
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
