{
  "cli": {
    "version": ">= 16.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "apk": {
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_API_URL": "https://api.phexuss.dev/api"
      },
      "android": {
        "buildType": "apk"
      }
    },
    "production": {
      "env": {
        "EXPO_PUBLIC_API_URL": "https://api.phexuss.dev/api"
      },
      "android": {
        "buildType": "app-bundle"
      }
    }
  }
}
